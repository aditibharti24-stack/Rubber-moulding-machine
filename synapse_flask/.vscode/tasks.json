{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Synapse: Install Requirements",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "requirements.txt"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Synapse: Run Flask App",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "run.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "FLASK_HOST": "127.0.0.1",
          "FLASK_PORT": "5000",
          "FLASK_DEBUG": "true",
          "FLASK_USE_RELOADER": "false"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "Synapse: Run Production-like",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "run.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "FLASK_HOST": "127.0.0.1",
          "FLASK_PORT": "5000",
          "FLASK_DEBUG": "false",
          "FLASK_USE_RELOADER": "false"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    }
  ]
}
